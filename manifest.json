{
  "manifest_version": 3,
  "name": "SharePoint Loader",
  "version": "0.1.0",
  "description": "Loads every dynamically rendered item in long SharePoint lists.",
  "content_scripts": [
    {
      "matches": [
        "https://*.sharepoint.com/*",
        "https://*.sharepoint.cn/*",
        "https://*.sharepoint.de/*",
        "https://*.sharepoint.us/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ]
}
